{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://*.tavusapi.com https://*.calendly.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://*.canva.com; connect-src 'self' https://tavusapi.com https://api.resend.com; frame-src 'self' https://calendly.com https://*.tavusapi.com; object-src 'none';"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/start",
      "destination": "/start.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/build-status",
      "destination": "/build-status.html"
    },
    {
      "source": "/brand-assets",
      "destination": "/brand-assets.html"
    },
    {
      "source": "/((?!start|privacy|terms|build-status|brand-assets|api).*)",
      "destination": "/index.html"
    }
  ]
}